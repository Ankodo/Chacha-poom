# ===== ProxyForge Configuration =====
# Copy to .env and fill in values: cp .env.example .env

# === Database ===
POSTGRES_DB=proxyforge
POSTGRES_USER=proxyforge
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# === Security ===
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
NODE_AGENT_SECRET=CHANGE_ME_NODE_AGENT_SECRET

# === App ===
DEBUG=false
CORS_ORIGINS=["https://panel.yourdomain.com"]

# === Domains ===
PANEL_DOMAIN=panel.yourdomain.com
SUB_DOMAIN=sub.yourdomain.com
CLIENT_DOMAIN=yourdomain.com

# === Telegram Bot ===
BOT_TOKEN=

# === Payments — YooKassa ===
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=

# === Payments — CryptoBot ===
CRYPTOBOT_TOKEN=

# === SuperAdmin (initial setup) ===
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
