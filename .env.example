# ===== ProxyForge Environment =====

# Database
POSTGRES_DB=proxyforge
POSTGRES_USER=proxyforge
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+asyncpg://proxyforge:change-me-strong-password@db:5432/proxyforge

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change-me-generate-with-openssl-rand-hex-64

# App
DEBUG=true
CORS_ORIGINS=["http://localhost:3001","http://localhost:3002"]

# Telegram Bot
BOT_TOKEN=

# Payments
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
CRYPTOBOT_TOKEN=

# Sub-link
SUB_DOMAIN=sub.localhost

# Node Agent
NODE_AGENT_SECRET=change-me-node-agent-secret

# SuperAdmin (initial setup)
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=change-me-admin-password
