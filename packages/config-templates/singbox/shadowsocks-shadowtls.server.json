{
  "inbounds": [
    {
      "tag": "{{INBOUND_TAG}}-shadowtls",
      "type": "shadowtls",
      "listen": "::",
      "listen_port": {{PORT}},
      "version": 3,
      "users": [
        {
          "name": "{{SHADOWTLS_USER}}",
          "password": "{{SHADOWTLS_PASSWORD}}"
        }
      ],
      "handshake": {
        "server": "{{SHADOWTLS_HANDSHAKE_SERVER}}",
        "server_port": 443
      },
      "strict_mode": true,
      "detour": "{{INBOUND_TAG}}-shadowsocks"
    },
    {
      "tag": "{{INBOUND_TAG}}-shadowsocks",
      "type": "shadowsocks",
      "listen": "127.0.0.1",
      "method": "2022-blake3-aes-128-gcm",
      "password": "{{SS_PASSWORD}}",
      "users": []
    }
  ]
}
