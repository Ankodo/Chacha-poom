{
  "protocol_uri": "vless://{{UUID}}@{{HOST}}:{{PORT}}?type=grpc&security=reality&sni={{SNI}}&fp={{FINGERPRINT}}&pbk={{PUBLIC_KEY}}&sid={{SHORT_ID}}&serviceName={{GRPC_SERVICE_NAME}}&mode=multi#{{REMARK}}",
  "clash": {
    "name": "{{REMARK}}",
    "type": "vless",
    "server": "{{HOST}}",
    "port": {{PORT}},
    "uuid": "{{UUID}}",
    "network": "grpc",
    "tls": true,
    "udp": true,
    "servername": "{{SNI}}",
    "grpc-opts": {
      "grpc-service-name": "{{GRPC_SERVICE_NAME}}"
    },
    "reality-opts": {
      "public-key": "{{PUBLIC_KEY}}",
      "short-id": "{{SHORT_ID}}"
    },
    "client-fingerprint": "{{FINGERPRINT}}"
  },
  "singbox": {
    "tag": "{{REMARK}}",
    "type": "vless",
    "server": "{{HOST}}",
    "server_port": {{PORT}},
    "uuid": "{{UUID}}",
    "flow": "",
    "transport": {
      "type": "grpc",
      "service_name": "{{GRPC_SERVICE_NAME}}"
    },
    "tls": {
      "enabled": true,
      "server_name": "{{SNI}}",
      "utls": {
        "enabled": true,
        "fingerprint": "{{FINGERPRINT}}"
      },
      "reality": {
        "enabled": true,
        "public_key": "{{PUBLIC_KEY}}",
        "short_id": "{{SHORT_ID}}"
      }
    }
  }
}
