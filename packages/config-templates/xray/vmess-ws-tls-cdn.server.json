{
  "inbounds": [
    {
      "tag": "{{INBOUND_TAG}}",
      "listen": "0.0.0.0",
      "port": {{PORT}},
      "protocol": "vmess",
      "settings": {
        "clients": []
      },
      "streamSettings": {
        "network": "ws",
        "security": "tls",
        "tlsSettings": {
          "certificates": [
            {
              "certificateFile": "{{CERT_FILE}}",
              "keyFile": "{{KEY_FILE}}"
            }
          ],
          "alpn": ["h2", "http/1.1"],
          "fingerprint": "{{FINGERPRINT}}"
        },
        "wsSettings": {
          "path": "{{WS_PATH}}",
          "headers": {
            "Host": "{{CDN_DOMAIN}}"
          }
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    }
  ]
}
