{
  "inbounds": [
    {
      "tag": "{{INBOUND_TAG}}",
      "listen": "0.0.0.0",
      "port": {{PORT}},
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "h2",
        "security": "tls",
        "tlsSettings": {
          "certificates": [
            {
              "certificateFile": "{{CERT_FILE}}",
              "keyFile": "{{KEY_FILE}}"
            }
          ],
          "alpn": ["h2"],
          "fingerprint": "{{FINGERPRINT}}"
        },
        "httpSettings": {
          "host": ["{{CDN_DOMAIN}}"],
          "path": "{{H2_PATH}}"
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    }
  ]
}
