{
    admin off
    # Auto HTTPS when using real domains; HTTP-only for IP addresses
    auto_https disable_redirects
}

# Main panel — serves admin panel, API, and sub-links
# Works with both domain names and IP addresses
:80 {
    # API endpoints
    handle /api/* {
        reverse_proxy backend:8000
    }

    # Sub-link endpoint
    handle /sub/* {
        reverse_proxy backend:8000
    }

    # Node install script
    handle /install-node.sh {
        root * /srv
        file_server
    }

    # Admin panel SPA (catch-all)
    handle {
        root * /srv/admin
        file_server
        try_files {path} /index.html
    }
}

# HTTPS block — activated only when PANEL_DOMAIN is a real domain (not IP)
# Uncomment and set domains when you have DNS configured:
